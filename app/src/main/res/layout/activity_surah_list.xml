<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/bg_app" android:paddingTop="16dp">
    <!--  شريط البحث + زر الرجوع  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="12dp" android:gravity="center_vertical">
        <!--  شريط البحث  -->
        <LinearLayout android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:background="@drawable/bg_search_bar" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="8dp" android:layout_marginEnd="10dp">
            <!--  أيقونة البحث  -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔍" android:textSize="18sp" android:layout_marginEnd="8dp" />
            <!--  حقل البحث  -->
            <EditText android:id="@+id/etSearch" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@null" android:hint="@string/search_hint" android:textColorHint="@color/search_hint_color" android:textColor="@color/text_dark_gray" android:textSize="15sp" android:gravity="center_vertical|end" android:imeOptions="actionSearch" android:inputType="text" android:layoutDirection="rtl"/>
        </LinearLayout>
        <!--  زر الرجوع  -->
        <Button android:id="@+id/btnBack" style="@style/Btn.Yellow" android:layout_width="46dp" android:layout_height="46dp" android:text="›" android:textSize="22sp" android:textColor="@color/text_dark_gray"/>
    </LinearLayout>
    <!--  قائمة السور  -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerSurahs" android:layout_width="match_parent" android:layout_height="match_parent" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="4dp" android:clipToPadding="false"/>
</LinearLayout>