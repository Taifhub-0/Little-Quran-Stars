<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- رأس: اسم السورة + زر رجوع -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="rtl"
            android:layout_marginBottom="16dp">

            <!-- عداد التكرار -->
            <LinearLayout
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_repeat_header"
                    android:textSize="11sp"
                    android:textColor="@color/text_black"/>
                <TextView
                    android:id="@+id/tvRepeatCounterDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 / 3"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_green"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">
                <TextView
                    android:id="@+id/tvSurahNameDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سُورَةُ النَّاس"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark_green"/>
                <TextView
                    android:id="@+id/tvVerseRangeDone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="الآية 6 من 6"
                    android:textColor="@color/text_gray"
                    android:textStyle="bold"
                    android:textSize="13sp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnBack"
                style="@style/Btn.Yellow"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:text="›"
                android:textSize="22sp"/>
        </LinearLayout>

        <!-- كارد الإنجاز -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_white"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- النجمة -->
            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center_horizontal">
                <View
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:background="@color/bg_star_circle"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⭐"
                    android:textSize="80sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="6dp"
                    android:text="🌟"
                    android:textSize="28sp"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/completion_title"
                android:textColor="@color/text_green"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:text="@string/completion_subtitle"
                android:textColor="@color/text_black"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btnStartQuiz"
                style="@style/Btn.Yellow"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:text="🎯 ابدأ الاختبار"/>

            <Button
                android:id="@+id/btnRepeatAgain"
                style="@style/Btn.Green"
                android:layout_height="54dp"
                android:layout_marginBottom="12dp"
                android:text="@string/btn_repeat_again"/>

            <Button
                android:id="@+id/btnBackHome"
                style="@style/Btn.Outline"
                android:layout_height="45dp"
                android:text="@string/btn_back_home"
                android:textColor="@color/text_white"/>
        </LinearLayout>

        <!-- شريط التقدم 100% -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="rtl"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_full_progress"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark_green"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="13sp"
                    android:textColor="@color/text_green"
                    android:background="@color/bg_counter_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBarDone"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/progress_fill"
                android:progressBackgroundTint="@color/progress_bg"/>
        </LinearLayout>

        <!-- أزرار التحكم -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layoutDirection="rtl">
            <Button
                android:id="@+id/btnPrevious"
                style="@style/Btn.SideControl"
                android:text="⏮"
                android:textColor="@color/text_black"
                android:alpha="0.5"
                android:enabled="false"
                android:layout_marginEnd="20dp"/>
            <Button
                android:id="@+id/btnPlayPause"
                style="@style/Btn.PlayCircle"
                android:text="◀"
                android:alpha="0.5"
                android:enabled="false"/>
            <Button
                android:id="@+id/btnNext"
                style="@style/Btn.SideControl"
                android:text="⏭"
                android:textColor="@color/text_black"
                android:alpha="0.5"
                android:enabled="false"
                android:layout_marginStart="20dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>