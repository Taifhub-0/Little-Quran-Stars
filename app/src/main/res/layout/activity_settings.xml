<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_app"
    android:layoutDirection="rtl"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="20dp">

    <!-- رأس الشاشة -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <Button
            android:id="@+id/btnBack"
            style="@style/Btn.Yellow"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:text="›"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚙️ الإعدادات"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark_green"/>
    </LinearLayout>

    <!-- الوضع الليلي -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌙 الوضع الليلي"
            android:textSize="17sp"
            android:textColor="@color/text_dark_green"
            android:textStyle="bold"/>

        <Switch
            android:id="@+id/switchNightMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="🔤 حجم الخط"
            android:textColor="@color/text_dark_green"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFontLarge"
                style="@style/Btn.Green"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="كبير"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnFontMedium"
                style="@style/Btn.Green"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="وسط"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnFontSmall"
                style="@style/Btn.Green"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="صغير"
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </LinearLayout>
    <!-- مدة الانتظار بين التكرارات -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="⏱ مدة الانتظار بين التكرارات"
            android:textColor="@color/text_dark_green"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn2Sec"
                style="@style/Btn.Green"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="2 ثانية"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn4Sec"
                style="@style/Btn.Green"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="4 ثواني "
                android:textSize="13sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn6Sec"
                style="@style/Btn.Green"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="6 ثواني "
                android:textSize="13sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎙 القارئ المفضل"
            android:textSize="17sp"
            android:textColor="@color/text_dark_green"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <Spinner
            android:id="@+id/spinnerReader"
            android:layout_width="match_parent"
            android:layout_height="44dp"/>
    </LinearLayout>

    <!-- زر الحفظ -->
    <Button
        android:id="@+id/btnSaveSettings"
        style="@style/Btn.Green"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="← رجوع"/>

</LinearLayout>