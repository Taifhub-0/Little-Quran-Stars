<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp">

        <!-- رأس الشاشة -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layoutDirection="rtl"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:orientation="vertical"
                android:background="@drawable/bg_card_white"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_repeat_header"
                    android:textSize="11sp"
                    android:textColor="@color/text_gray"/>
                <TextView
                    android:id="@+id/tvRepeatCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1 / 3"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_green"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">
                <TextView
                    android:id="@+id/tvSurahNameHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سُورَةُ النَّاس"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark_green"/>
                <TextView
                    android:id="@+id/tvVerseProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الآية 1 من 6"
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnBack"
                style="@style/Btn.Yellow"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:text="›"
                android:textSize="22sp"/>
        </LinearLayout>

        <!-- صورة صفحة المصحف -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="430dp"
            android:background="@drawable/bg_mushaf_card"
            android:layout_marginBottom="10dp">

            <ImageView
                android:id="@+id/imgMushafPage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:contentDescription="صورة صفحة المصحف"
                android:src="@null"
                android:background="@color/bg_mushaf_card"/>

            <TextView
                android:id="@+id/tvVerseBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_button_yellow"
                android:text="📖 سُورَةُ النَّاس : آية 1"
                android:textColor="@color/text_dark_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>
        </FrameLayout>

        <!-- نص الآية -->
        <TextView
            android:id="@+id/tvCurrentVerse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/yellow_accent"
            android:padding="10dp"
            android:gravity="center"
            android:textSize="18sp"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:text="جاري التحميل..."/>

        <!-- شريط التقدم -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layoutDirection="rtl"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_verse_progress"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark_green"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6%"
                    android:textSize="13sp"
                    android:textColor="@color/text_green"
                    android:background="@color/bg_counter_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="14dp"
                android:max="100"
                android:progress="6"
                android:progressTint="@color/progress_fill"
                android:progressBackgroundTint="@color/progress_bg"/>
        </LinearLayout>

        <!-- أزرار التحكم -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layoutDirection="rtl"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnPrevious"
                style="@style/Btn.SideControl"
                android:text="⏮"
                android:layout_marginEnd="20dp"/>

            <Button
                android:id="@+id/btnPlayPause"
                style="@style/Btn.PlayCircle"
                android:text="◀"/>

            <Button
                android:id="@+id/btnNext"
                style="@style/Btn.SideControl"
                android:text="⏭"
                android:layout_marginStart="20dp"/>
        </LinearLayout>

        <!-- زر الإيقاف المؤقت -->
        <Button
            android:id="@+id/btnPauseAndResume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:text="⏸ إيقاف مؤقت وأكمل لاحقاً"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="@color/green_primary"/>

    </LinearLayout>
</ScrollView>